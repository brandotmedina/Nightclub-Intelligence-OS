# Copy this file to .env.local and fill in your values.
# Find Supabase values at: supabase.com -> your project -> Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The UUID of the active client/venue (from the clients table).
# Used to filter all database queries by tenant.
CLIENT_ID=your-client-uuid-here

# Stripe (use TEST keys during development; swap for live keys to go live)
# Find these at dashboard.stripe.com -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase service role key — bypasses RLS, server-side only
# Find this at supabase.com -> your project -> Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Full URL of your app (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
